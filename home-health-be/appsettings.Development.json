{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:8080"
  ],
  "Authentication": {
    "OktaEnabled": false
  },
  "Database": {
    "Host": "",
    "Database": "",
    "User": "",
    "Password": ""
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server={server};Initial Catalog={database};Persist Security Info=False;User ID={user};Password={password};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Okta": {
    "Domain": "{okta_domain}",
    "ClientId": "{okta_client_id}"
  },
  "MicrosoftGraph": {
    "Instance": "https://login.microsoftonline.com/",
    "ClientId": "{ms_client_id}",
    "TenantId": "{ms_tenant_id}",
    "ClientSecret": "{ms_client_secret}",
    "Scopes": [ "https://graph.microsoft.com/.default" ]
  },
  "ADSecurityGroups": {
    "User": "{ad_group_id_user}",
    "Approver": "{ad_group_id_approver}",
    "Report": "{ad_group_id_report}",
    "Leader": "{ad_group_id_leader}"
  },
  "SharePoint": {
    "SiteUrl": "{sharepoint_site_url}",
    "SiteId": "{sharepoint_site_id}",
    "DriveId": "{sharepoint_drive_id}"
  }
}
